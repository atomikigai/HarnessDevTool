{
  "$schema": "https://schema.tauri.app/config/2.json",
  "productName": "HarnessDevTool",
  "version": "0.1.0",
  "identifier": "org.ciat.harness",
  "build": {
    "beforeDevCommand": "pnpm --dir ../frontend dev",
    "devUrl": "http://localhost:43178",
    "beforeBuildCommand": "pnpm --dir ../frontend run build:tauri",
    "frontendDist": "../frontend/build-tauri"
  },
  "app": {
    "windows": [
      {
        "title": "HarnessDevTool",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/harness-server"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
