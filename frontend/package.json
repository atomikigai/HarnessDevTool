{
  "name": "harness-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:tauri": "BUILD_TARGET=tauri PUBLIC_API_BASE=http://localhost:43177/api vite build",
    "preview": "vite preview",
    "start": "node build/index.js",
    "test": "pnpm check",
    "test:e2e": "playwright test --project=chromium --reporter=line",
    "test:e2e:headed": "playwright test --project=chromium --headed --reporter=line",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.20.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.7",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.14.0",
    "paneforge": "1.0.0-next.6",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.20.0",
    "svelte-check": "^4.1.4",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@tanstack/svelte-virtual": "^3.13.26",
    "@tanstack/virtual-core": "^3.16.0",
    "@tauri-apps/api": "^2.11.0",
    "bits-ui": "^1.3.0",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.3.0",
    "dompurify": "^3.4.6",
    "ghostty-web": "^0.4.0",
    "lucide-svelte": "^0.469.0",
    "marked": "^18.0.4",
    "mode-watcher": "^0.5.1",
    "svelte-sonner": "^0.3.28",
    "tailwind-merge": "^2.6.0",
    "tailwind-variants": "^0.3.1",
    "valibot": "^1.4.1"
  },
  "packageManager": "pnpm@11.3.0"
}
