layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="code" {
        pane
    }

    tab name="dev logs" focus=true {
        pane split_direction="vertical" {
            pane name="mcp" command="just" {
                args "dev-mcp"
            }
            pane name="backend" command="just" {
                args "dev-backend"
            }
            pane name="frontend" command="just" {
                args "dev-frontend"
            }
        }
    }
}
