HARNESS_API_TOKEN=change-me
# Local frontend dev needs the same token to call mutating API routes.
# `just dev` derives this automatically from HARNESS_API_TOKEN unless overridden.
# PUBLIC_HARNESS_API_TOKEN=change-me
RUST_LOG=info

# Optional secret for Context7. `.env` is versioned in this repo by policy;
# use the value intentionally committed there or override it in your shell.
# CONTEXT7_API_KEY=ctx7sk-...

# Optional. Leave unset to use the backend default: $HOME/.harness.
# HARNESS_HOME=/home/you/.harness

# Optional. Base directory allowed for knowledge/file ingestion source_path.
# HARNESS_DATA_ROOT=/home/you/data

# Optional. Leave unset for local dev so Justfile/Zellij choose free high ports.
# BACKEND_PORT=43177
# FRONTEND_PORT=43178
